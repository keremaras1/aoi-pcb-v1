{
  "generator": {
    "gen_train": true,
    "gen_val": true,
    "image_sources": {
      "backlayer_path": "pcb_images/pcb_backlayer.png",
      "ic_path": "pcb_images/ic.png"
    },
    "train_data": {
      "dataset_size": 2000,
      "rotation_angle": 10,
      "delta": 0.1,
      "data_dir": "datasets/training/training_dataset",
      "labels_dir": "datasets/training",
      "label_file": "training.csv",
      "seed": 42
    },
    "val_data": {
      "dataset_size": 2000,
      "rotation_angle": 10,
      "delta": 0.1,
      "data_dir": "datasets/validation/validation_dataset",
      "labels_dir": "datasets/validation",
      "label_file": "validation.csv",
      "seed": 123
    }
  },
  "encoder": {
    "train_data_splice": null,
    "normalize_data": false,
    "normalize_labels": true
  },
  "model": {
    "saved_models_dir": "",
    "load_model": ""
  },
  "training": {
    "optimizer_lr": 0.001,
    "val_split": 0.15,
    "n_epochs": 1000,
    "early_stopping": {
      "monitor": "val_loss",
      "min_delta": 0.0,
      "patience": 30,
      "verbose": 1,
      "restore_best_weights": true
    },
    "lr_schedule": {
      "monitor": "val_loss",
      "factor": 0.5,
      "patience": 15,
      "verbose": 1,
      "min_lr": 0.00001
    }
  },
  "metrics": {
    "x_weight": 1.0,
    "y_weight": 1.0,
    "angle_weight": 1.0
  }
}
